# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── JWT (REQUIRED — use a long random string, never commit the real value) ───
JWT_SECRET=change_me_to_a_long_random_string

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:
DB_PATH=/data/renthub.db
# Railway (after adding a Volume mounted at /data):
# DB_PATH=/data/renthub.db

# ─── File uploads directory ───────────────────────────────────────────────────
UPLOADS_DIR=./uploads

# ─── Frontend URL for CORS (REQUIRED in production) ──────────────────────────
# Set to your deployed Railway frontend URL — no trailing slash
FRONTEND_URL=https://your-frontend.up.railway.app

# ─── Backend public URL ───────────────────────────────────────────────────────
BASE_URL=https://your-backend.up.railway.app

# ─── Email / Nodemailer ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Rent Hub <your_email@gmail.com>

# ─── Cloudinary (REQUIRED for image uploads to survive redeployment) ─────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── M-Pesa Daraja ────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# REQUIRED: update to your real backend URL before enabling M-Pesa
MPESA_CALLBACK_URL=https://your-backend.up.railway.app/api/payments/mpesa/callback
MPESA_ENV=sandbox






































# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/renthub.db

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:3001

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Use Gmail with an App Password (not your main password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Rent Hub <your_email@gmail.com>

# ─── Cloudinary (Image Hosting) ───────────────────────────────────────────────
# Get free credentials at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── M-Pesa Daraja ────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox
